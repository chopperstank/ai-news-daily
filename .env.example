# AI News Daily 环境变量模板
# 复制此文件为 .env 并填写真实值

# ─── 阿里百炼 API ───
DASHSCOPE_API_KEY=sk-your-api-key-here
AI_MODEL=qwen3.5-flash

# ─── 数据采集配置 ───
MAX_ITEMS_PER_SOURCE=10
MAX_ITEMS_FOR_SUMMARY=30

# ─── 数据库同步配置（可选，不配置则跳过同步） ───
NEWS_API_URL=https://url:9966/api/news/batch
NEWS_API_TOKEN=your-random-token-here
